datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  RESOLVED
  SNOOZED
}

enum SenderType {
  USER
  INSTAGRAM_USER
  SYSTEM
}

enum TriggerType {
  KEYWORD         // DM keyword match
  AI_FALLBACK     // AI reply when no keyword matches
  COMMENT         // Comment on post/reel triggers DM
  ALL_COMMENTS    // Any comment on post triggers DM
  STORY_REPLY     // Story reply triggers DM
  FOLLOW_GATE     // Only reply if user follows account
}

enum PostTriggerScope {
  SPECIFIC_POST   // Only one specific post
  ALL_POSTS       // All posts and reels
  NEXT_POST       // Only next published post
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  teamMembers   TeamMember[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  conversations Conversation[]
}

model Workspace {
  id                String             @id @default(cuid())
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  teamMembers       TeamMember[]
  instagramAccounts InstagramAccount[]
  automations       Automation[]
  aiPrompts         AiPrompt[]
  subscriptions     Subscription[]
  invoices          Invoice[]
  activityLogs      ActivityLog[]
  conversationFlows ConversationFlow[]
}

model TeamMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        Role      @default(AGENT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model InstagramAccount {
  id                 String         @id @default(cuid())
  workspaceId        String
  instagramAccountId String         @unique
  username           String
  displayName        String?
  accessToken        String
  pageId             String?
  pageAccessToken    String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  contacts           Contact[]
}

model Contact {
  id                 String           @id @default(cuid())
  instagramAccountId String
  instagramUserId    String
  username           String
  name               String?
  labels             Json?
  notes              String?
  lastMessageAt      DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  
  instagramAccount   InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  conversations      Conversation[]

  @@unique([instagramAccountId, instagramUserId])
}

model Conversation {
  id                 String             @id @default(cuid())
  instagramAccountId String
  contactId          String
  status             ConversationStatus @default(OPEN)
  assignedToId       String?
  isStarred          Boolean            @default(false)
  isArchived         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  instagramAccount   InstagramAccount   @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  contact            Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo         User?              @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  messages           Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  senderType     SenderType
  text           String
  attachments    Json?
  createdAt      DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Automation {
  id           String           @id @default(cuid())
  workspaceId  String
  name         String
  isActive     Boolean          @default(true)
  priority     Int              @default(0)
  delaySeconds Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rules        AutomationRule[]
}

model AutomationRule {
  id               String            @id @default(cuid())
  automationId     String
  triggerType      TriggerType       @default(KEYWORD)
  triggerValue     String            // keyword text or empty for ALL_COMMENTS
  replyText        String            // DM reply message
  commentReply     String?           // Optional public comment reply
  smartMatch       Boolean           @default(false) // Fuzzy keyword matching
  postTriggerScope PostTriggerScope  @default(ALL_POSTS)
  postId           String?           // Specific Instagram post/reel ID
  postUrl          String?           // Post URL for display
  requireFollow    Boolean           @default(false) // Follow-gate toggle
  flowId           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  automation       Automation        @relation(fields: [automationId], references: [id], onDelete: Cascade)
  flow             ConversationFlow? @relation(fields: [flowId], references: [id], onDelete: SetNull)
}

model ConversationFlow {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps       FlowStep[]
  rules       AutomationRule[]
}

model FlowStep {
  id           String           @id @default(cuid())
  flowId       String
  stepOrder    Int
  message      String
  waitForReply Boolean          @default(false)
  matchValue   String?
  nextStepId   String?
  createdAt    DateTime         @default(now())
  
  flow         ConversationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model AiPrompt {
  id          String    @id @default(cuid())
  workspaceId String
  name        String    @default("Default Assistant")
  promptText  String
  tone        String    @default("helpful")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String
  stripeSubscriptionId String    @unique
  stripeCustomerId     String
  plan                 PlanType  @default(FREE)
  status               String
  currentPeriodEnd     DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String    @id @default(cuid())
  workspaceId     String
  stripeInvoiceId String    @unique
  amount          Int
  currency        String
  status          String
  pdfUrl          String?
  createdAt       DateTime  @default(now())
  
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  action      String
  details     String?
  createdAt   DateTime  @default(now())
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}
